# Copy to .env.local and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
# For production (Vercel Postgres, Neon, Supabase, etc.):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# ─── LLM providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=       # for /api/llm/evaluate (fit score) + /api/fit
ANTHROPIC_API_KEY=    # for /api/llm/chat (advisor)
