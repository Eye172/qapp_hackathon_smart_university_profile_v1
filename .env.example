# Copy to .env.local and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
# For production (Vercel Postgres, Neon, Supabase, etc.):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# ─── OpenAI (all AI features) ────────────────────────────────────────────────
# Used for: RS fit scoring (/api/llm/evaluate), AI Advisor chat (/api/llm/chat)
OPENAI_API_KEY=sk-proj-...
# Optional model overrides (defaults shown):
# OPENAI_MODEL=gpt-4o-mini     ← fit scoring (fast + cheap)
# OPENAI_CHAT_MODEL=gpt-4o     ← advisor chat (high quality)
